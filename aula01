<!doctype html>
<html lang="pt-br">
    <head><!-- configurações basicas-->
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>MetaSteel</title>
        <style>
            :root{
                --primary:#2563eb;
                --sucess:#16034a;
                --warning:#f59e0b;
                --danger:#dc2626;
                --dark:#1f2937;
                --light:#f3f4f6;
                --wight:#ffffff;
                
            }
            *{
                margin:0;
                padding:0;
                box-sizing: border-box;
                font-family: Segoe UT, sans-serif;
            }
            body{
                background:  var(--light);
                display: flex;
            }
            .sidebar{
                width: 250px;
                height: 100vh;
                background: var(--dark);
                color: white;
                position: fixed;
                left: 0;
                top: 0;
            }
            .logo{
                padding: 20px;
                font-size: 24px;
                font-weight: bold;
                border-bottom: 1px solid rgba(255,255, 255,.1);
            }
            .menu{
                list-style: none;
            }
            .menu li{
                padding: 15px 20px;
                cursor: pointer;
                transition: 3s;
            }
            .menu li:hover{
                background: #374151;
            }
            .menu li.active{
                background: var(--primary);
            }
            .main{
                margin-left: 250px;
                width: calc(100%-250px);
                padding: 25px;
            }
            .header{
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 25px;
            }
            .header h1{
                color: #111827;
            }
            .user{
                background: white;
                padding: 10px 15px;
                border-radius: 8px;
                box-shadow: 0 2px 8px rgba(0, 0,0,.08);
            }
            .card{
                display: grid;
                grid-template-columns: repeat(auto-fit,minmax(220px, 1fr));
                gap: 20px;
                margin-bottom: 30px;
            }
            .card{
                background: white;
                padding: 20px;
                border-radius: 12px;
                box-shadow: 0 2px 8px rgba(0,0,0,.08);
            }
            .card h3{
                color: #6b7280;
                font-size: 14px;
                margin-bottom: 10px;
            }
            .card .value{
                font-size: 28px;
                font-weight: bold;
            }
            .blue{color: var(--primary);}
            .green{color: var(--sucess);}
            .orange{color: var(--warning);}
            .red{color: var(--danger);}
            
            .panel{
                background: white;
                border-radius: 12px;
                padding: 20px;
                margin-bottom: 25px;
                box-shadow: 0 2px 8px rgba(0,0,0,.08);
            }
        </style>
        
        
    </head>
    <body>
        <div class="sidebar"><!--logo-->
            <div class="logo">MetaSteel</div>
            <ul class="menu">
                <li>Dashboard</li>
                <li class="active">Vendas</li>
                <li>Estoque</li>
                <li>Compras</li>
                <li>Financeiro</li>
                <li>Clientes</li>
                <li>Relatório</li>
            </ul>
        </div>
        <div class="header">
            <h1>Vendas e Estoque</h1>
            <div class="user">
                Administrador
            </div>
        </div>
        <div class="cards">
            <h3>Faturamento Mensal</h3>
            <div class="value blue">R$125.800</div>
        </div>
        <div class="cards">
            <h3>Pedidos</h3>
            <div class="value green">842</div>
        </div>
        <div class="cards">
            <h3>Produto em Estoquee</h3>
            <div class="value orange">R$4.320</div>
        </div>
        <div class="cards">
            <h3>Itens críticos</h3>
            <div class="value red">R$18</div>
        </div>
        <div class="panel">
        <div class="panel-title"><h2>útimas vendas</h2>
        <table>
            <thead>
                <tr>
                    <th>Pedido</th>
                    <th>Cliente</th>
                    <th>Valor</th>
                    <th>Data</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>#1025</td>
                    <td>Mecado Alfa</td>
                    <td>R$3.500</td>
                    <td>12/06/2026</td>
                    <td><span class="status pago">Pago</span></td>
                </tr>
                <tr>
                    <td>#1026</td>
                    <td>Loja beta</td>
                    <td>R$1850</td>
                    <td>13/06/2026</td>
                    <td><span class="status pendente">Pendente</span></td>
                   </tr>
                <tr>
                    <td>#1027</td>
                    <td>Empresa Delta</td>
                    <td>R$5.700</td>
                    <td>14/06/2026</td>
                    <td><span class="status cancelado">Pago</span></td>
                </tr>
            </tbody>
        </table>
        </div>
        <div class="panel">
            <h2 class="panel-title">Controle de Estoque</h2>
            <table>
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Produto</th>
                        <th>Categoria</th>
                        <th>Quantidade</th>
                        <th>Situação</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>P001</td>
                        <td>Notebbok Dell</td>
                        <td>Informática</td>
                        <td>35</td>
                        <td class="stock-ok">Normal</td>
                    </tr>
                    <tr>
                        <td>P002</td>
                        <td>Monitor LG 24</td>
                        <td>Informática</td>
                        <td>8</td>
                        <td class="stock-ok">baixo</td>
                    </tr>
                    <tr>
                        <td>P003</td>
                        <td>Mouse Wireless</td>
                        <td>Acessórios</td>
                        <td>120</td>
                        <td class="stock-ok">Normal</td>
                    </tr>
                    <tr>
                        <td>P004</td>
                        <td>teclado Mecânico</td>
                        <td>Acessórios</td>
                        <td>4</td>
                        <td class="stock-low">Reposição Urgente</td>
                    </tr>
                </tbody>
            </table>
        </div>
        </div>
    </body>
</html>
