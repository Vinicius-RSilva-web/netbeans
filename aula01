    <!doctype html>
    <html lang="pt-br">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>MetaSteel</title>

        <style>
            :root{
                --primary:#2563eb;
                --success:#16034a;
                --warning:#f59e0b;
                --danger:#dc2626;
                --dark:#1f2937;
                --light:#f3f4f6;
                --white:#ffffff;
            }

            *{
                margin:0;
                padding:0;
                box-sizing: border-box;
                font-family: Segoe UI, sans-serif;
            }

            body{
                background: var(--light);
                display: flex;
            }

            .sidebar{
                width: 250px;
                height: 100vh;
                background: var(--dark);
                color: white;
                position: fixed;
                left: 0;
                top: 0;
            }

            .logo{
                padding: 20px;
                font-size: 24px;
                font-weight: bold;
                border-bottom: 1px solid rgba(255,255,255,.1);
            }

            .menu{
                list-style: none;
            }

            .menu li{
                padding: 15px 20px;
                cursor: pointer;
                transition: 0.3s;
            }

            .menu li:hover{
                background: #374151;
            }

            .menu li.active{
                background: var(--primary);
            }

            .main{
                margin-left: 250px;
                width: calc(100% - 250px);
                padding: 25px;
            }

            .header{
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 25px;
            }

            .user{
                background: white;
                padding: 10px 15px;
                border-radius: 8px;
                box-shadow: 0 2px 8px rgba(0,0,0,.08);
            }

            .cards{
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
                gap: 20px;
                margin-bottom: 30px;
            }

            .card{
                background: white;
                padding: 20px;
                border-radius: 12px;
                box-shadow: 0 2px 8px rgba(0,0,0,.08);
            }

            .card h3{
                color: #6b7280;
                font-size: 14px;
                margin-bottom: 10px;
            }

            .value{
                font-size: 28px;
                font-weight: bold;
            }

            .blue{color: var(--primary);}
            .green{color: var(--success);}
            .orange{color: var(--warning);}
            .red{color: var(--danger);}

            .panel{
                background: white;
                border-radius: 12px;
                padding: 20px;
                margin-bottom: 25px;
                box-shadow: 0 2px 8px rgba(0,0,0,.08);
            }

            table{
                width: 100%;
                border-collapse: collapse;
                margin-top: 15px;
            }

            th, td{
                padding: 10px;
                text-align: left;
                border-bottom: 1px solid #ddd;
            }

            th{
                background: #f9fafb;
            }
        </style>
    </head>

    <body>

    <div class="sidebar">
        <div class="logo">MetaSteel</div>
        <ul class="menu">
            <li>Dashboard</li>
            <li class="active">Vendas</li>
            <li>Estoque</li>
            <li>Compras</li>
            <li>Financeiro</li>
            <li>Clientes</li>
            <li>Relatório</li>
        </ul>
    </div>

    <div class="main">

        <div class="header">
            <h1>Vendas e Estoque</h1>
            <div class="user">Administrador</div>
        </div>

        <div class="cards">
            <div class="card">
                <h3>Faturamento Mensal</h3>
                <div class="value blue">R$125.800</div>
            </div>

            <div class="card">
                <h3>Pedidos</h3>
                <div class="value green">842</div>
            </div>

            <div class="card">
                <h3>Produtos em Estoque</h3>
                <div class="value orange">4.320</div>
            </div>

            <div class="card">
                <h3>Itens Críticos</h3>
                <div class="value red">18</div>
            </div>
        </div>

        <div class="panel">
            <h2>Últimas vendas</h2>
            <table>
                <thead>
                    <tr>
                        <th>Pedido</th>
                        <th>Cliente</th>
                        <th>Valor</th>
                        <th>Data</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>#1025</td>
                        <td>Mercado Alfa</td>
                        <td>R$3.500</td>
                        <td>12/06/2026</td>
                        <td>Pago</td>
                    </tr>
                    <tr>
                        <td>#1026</td>
                        <td>Loja Beta</td>
                        <td>R$1.850</td>
                        <td>13/06/2026</td>
                        <td>Pendente</td>
                    </tr>
                    <tr>
                        <td>#1027</td>
                        <td>Empresa Delta</td>
                        <td>R$5.700</td>
                        <td>14/06/2026</td>
                        <td>Pago</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="panel">
            <h2>Controle de Estoque</h2>
            <table>
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Produto</th>
                        <th>Categoria</th>
                        <th>Quantidade</th>
                        <th>Situação</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>P001</td>
                        <td>Notebook Dell</td>
                        <td>Informática</td>
                        <td>35</td>
                        <td>Normal</td>
                    </tr>
                    <tr>
                        <td>P002</td>
                        <td>Monitor LG 24</td>
                        <td>Informática</td>
                        <td>8</td>
                        <td>Baixo</td>
                    </tr>
                    <tr>
                        <td>P003</td>
                        <td>Mouse Wireless</td>
                        <td>Acessórios</td>
                        <td>120</td>
                        <td>Normal</td>
                    </tr>
                    <tr>
                        <td>P004</td>
                        <td>Teclado Mecânico</td>
                        <td>Acessórios</td>
                        <td>4</td>
                        <td>Reposição Urgente</td>
                    </tr>
                </tbody>
            </table>
        </div>

    </div>

</body>
</html>

